SUPABASE_URL=
SUPABASE_ANON_KEY=
# Solo usado server-side en Edge Functions. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# KYC (Fase 1.4) — secrets del proyecto Supabase (Edge Functions), no del
# cliente. Configurar con `supabase secrets set NOMBRE=valor`.
# Sin configurar (o KYC_PROVIDER distinto de "truora"), kyc-start corre en
# modo DEMO: cualquier DNI escaneado se aprueba de inmediato, sin llamar a
# Truora. Para activar la verificación real:
#   supabase secrets set KYC_PROVIDER=truora
#   supabase secrets set TRUORA_API_KEY=<tu api key de Truora>
#   supabase secrets set TRUORA_WEBHOOK_SECRET=<secreto del webhook en Truora>
# y configurar en el panel de Truora el webhook hacia la URL de kyc-webhook
# desplegada (deployada con --no-verify-jwt: la valida su propia firma HMAC).
KYC_PROVIDER=demo
TRUORA_API_KEY=
TRUORA_WEBHOOK_SECRET=
